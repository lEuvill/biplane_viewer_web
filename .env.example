# Copy to .env and fill in all values before starting the server.
# Generate SECRET_KEY with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=generate-a-long-random-string-here
DEBUG=False
ALLOWED_HOSTS=your-server-ip,your-domain.com

# Include your domain with scheme so CSRF works over HTTPS
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Orthanc PACS — use localhost/127.0.0.1 when on the same server
ORTHANC_URL=http://127.0.0.1:8042
ORTHANC_USER=your-orthanc-username
ORTHANC_PASS=your-orthanc-password

# Redis — use localhost when on the same server
REDIS_URL=redis://127.0.0.1:6379

# How long decoded frames stay in Redis cache (seconds). Default: 86400 (24 h).
# Lower this if the server is RAM-constrained.
FRAME_TTL=86400
